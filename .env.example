# ─── Base de datos (PostgreSQL) ───────────────────────────────────────────────
DATABASE_URL="postgresql://tdapp_user:tdapp_dev_pass@localhost:5432/tdapp_dev?schema=public"

# ─── Auth (JWT) ───────────────────────────────────────────────────────────────
JWT_SECRET="cambia-este-secreto-en-produccion"

# ─── Proveedor de IA ──────────────────────────────────────────────────────────
# Valores posibles: "ollama" (local, por defecto) | "groq" (nube, requiere API key)
AI_PROVIDER="ollama"

# ─── Ollama (modelo local — activo cuando AI_PROVIDER=ollama) ─────────────────
OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_MODEL="llama3.1:8b"

# ─── Groq (nube — activo cuando AI_PROVIDER=groq) ────────────────────────────
# Obtén tu API key gratis en https://console.groq.com
# Modelos recomendados: llama-3.1-8b-instant (rápido) | llama-3.3-70b-versatile (mejor calidad)
GROQ_API_KEY=""
GROQ_MODEL="llama-3.1-8b-instant"
